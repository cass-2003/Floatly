<Window x:Class="DeskLite.ScratchPadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="速记便签"
        Width="720"
        Height="540"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="#181C24"
        Foreground="#F5F7FA"
        FontSize="13">
    <Border x:Name="RootBorder" Padding="16" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="188" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,14,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="SidebarTitle" Grid.Row="0" Text="便签列表" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10" />
                <TextBox x:Name="SearchBox" Grid.Row="1" Height="32" Padding="10,6" Margin="0,0,0,10"
                         TextChanged="SearchBox_TextChanged" />

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="NoteListPanel" />
                </ScrollViewer>

                <TextBlock x:Name="ListEmptyHint" Grid.Row="2" Text="点击 + 新建便签" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />

                <Button x:Name="NewNoteBtn" Grid.Row="3" Content="+ 新建便签" Height="34" Margin="0,10,0,0"
                        Click="NewNote_Click" Cursor="Hand" BorderThickness="0" />
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox x:Name="TitleBox" Grid.Row="0" Height="34" Padding="10,6" Margin="0,0,0,8"
                         TextChanged="Editor_TextChanged" />

                <TextBox x:Name="ContentBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" Padding="10,8"
                         TextChanged="Editor_TextChanged" />

                <StackPanel x:Name="ColorPanel" Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0" />

                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="PinBtn" Content="置顶" Padding="12,5" Margin="0,0,6,0"
                                Click="Pin_Click" Cursor="Hand" BorderThickness="1" />
                        <Button x:Name="DuplicateBtn" Content="复制" Padding="12,5" Margin="0,0,6,0"
                                Click="Duplicate_Click" Cursor="Hand" BorderThickness="1" />
                        <Button x:Name="CopyBtn" Content="导出到剪贴板" Padding="12,5" Margin="0,0,6,0"
                                Click="Copy_Click" Cursor="Hand" BorderThickness="1" />
                        <Button x:Name="DeleteBtn" Content="删除" Padding="12,5"
                                Click="Delete_Click" Cursor="Hand" BorderThickness="1" />
                    </StackPanel>
                    <TextBlock x:Name="SaveStatusText" Grid.Column="1" Text="" FontSize="11"
                               VerticalAlignment="Center" HorizontalAlignment="Right" />
                </Grid>

                <StackPanel x:Name="EditorEmptyPanel" Grid.Row="0" Grid.RowSpan="4"
                            VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="EditorEmptyHint" Text="选择或新建一条便签" FontSize="14" HorizontalAlignment="Center" />
                    <Button x:Name="EditorNewBtn" Content="+ 新建便签" Padding="16,8" Margin="0,12,0,0"
                            Click="NewNote_Click" Cursor="Hand" BorderThickness="0" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
