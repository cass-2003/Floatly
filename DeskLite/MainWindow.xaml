<Window x:Class="DeskLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeskLite"
        Width="300"
        Height="540"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SourceInitialized="Window_SourceInitialized">
    <Window.Resources>
        <SolidColorBrush x:Key="TodoTextBrush" Color="#E8ECF1" />
        <SolidColorBrush x:Key="TodoDeleteBrush" Color="#7E8796" />
    </Window.Resources>
    <Border x:Name="MainBorder"
            Background="#E8181C24"
            CornerRadius="12"
            BorderBrush="#40FFFFFF"
            BorderThickness="1"
            Padding="14">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="设置..." Click="OpenSettings_Click" />
                <Separator />
                <MenuItem Header="深色主题" Click="ThemeDark_Click" />
                <MenuItem Header="浅色主题" Click="ThemeLight_Click" />
                <Separator />
                <MenuItem Header="不透明 (100%)" Click="Opacity100_Click" />
                <MenuItem Header="轻微透明 (85%)" Click="Opacity85_Click" />
                <MenuItem Header="半透明 (70%)" Click="Opacity70_Click" />
                <MenuItem Header="高透明 (55%)" Click="Opacity55_Click" />
                <Separator />
                <MenuItem Header="周历视图" Click="CalWeekMode_Click" />
                <MenuItem Header="月历视图" Click="CalMonthMode_Click" />
                <MenuItem Header="回到今天" Click="CalToday_Click" />
                <MenuItem Header="跳转日期..." Click="CalJump_Click" />
            </ContextMenu>
        </Border.ContextMenu>
        <Grid PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown" Cursor="SizeAll">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="Transparent" Margin="0,0,0,6">
                <StackPanel>
                    <Grid>
                        <TextBlock x:Name="ClockText" Text="14:32:08" FontSize="26" FontWeight="SemiBold" Foreground="#F5F7FA" />
                        <TextBlock x:Name="DateText" Text="周四 6月11日" FontSize="13" Foreground="#B8C0CC"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock x:Name="LunarText" Text="农历五月初六 · 芒种" FontSize="12" Foreground="#C5D0E0" Margin="0,6,0,0" />
                    <TextBlock x:Name="LunarSubText" Text="乙巳年 · 属蛇 · 庚寅日" FontSize="11" Foreground="#7E8A9C" Margin="0,3,0,0" />
                    <Border x:Name="HuangLiPanel" Background="#18FFFFFF" CornerRadius="8" Padding="8,6" Margin="0,8,0,0"
                            Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="HuangLiYiLabel" Grid.Column="0" Text="宜" FontSize="11" FontWeight="SemiBold" Foreground="#4ADE80" VerticalAlignment="Top" Margin="0,2,0,0" />
                                <WrapPanel x:Name="HuangLiYiChips" Grid.Column="1" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="HuangLiJiLabel" Grid.Column="0" Text="忌" FontSize="11" FontWeight="SemiBold" Foreground="#F87171" VerticalAlignment="Top" Margin="0,2,0,0" />
                                <WrapPanel x:Name="HuangLiJiChips" Grid.Column="1" />
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="HuangLiMetaWuXing" Grid.Row="0" Grid.Column="0" Background="#14FFFFFF" CornerRadius="4" Padding="5,3" Margin="0,0,3,3">
                                    <StackPanel>
                                        <TextBlock x:Name="HuangLiWuXingLabel" Text="五行" FontSize="9" Foreground="#6B7280" />
                                        <TextBlock x:Name="HuangLiWuXingVal" FontSize="10" Foreground="#B8C0CC" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                                <Border x:Name="HuangLiMetaChong" Grid.Row="0" Grid.Column="1" Background="#14FFFFFF" CornerRadius="4" Padding="5,3" Margin="3,0,0,3">
                                    <StackPanel>
                                        <TextBlock x:Name="HuangLiChongLabel" Text="冲煞" FontSize="9" Foreground="#6B7280" />
                                        <TextBlock x:Name="HuangLiChongVal" FontSize="10" Foreground="#B8C0CC" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                                <Border x:Name="HuangLiMetaZhi" Grid.Row="1" Grid.Column="0" Background="#14FFFFFF" CornerRadius="4" Padding="5,3" Margin="0,3,3,0">
                                    <StackPanel>
                                        <TextBlock x:Name="HuangLiZhiLabel" Text="值神" FontSize="9" Foreground="#6B7280" />
                                        <TextBlock x:Name="HuangLiZhiVal" FontSize="10" Foreground="#B8C0CC" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                                <Border x:Name="HuangLiMetaJian" Grid.Row="1" Grid.Column="1" Background="#14FFFFFF" CornerRadius="4" Padding="5,3" Margin="3,3,0,0">
                                    <StackPanel>
                                        <TextBlock x:Name="HuangLiJianLabel" Text="建除" FontSize="9" Foreground="#6B7280" />
                                        <TextBlock x:Name="HuangLiJianVal" FontSize="10" Foreground="#B8C0CC" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel x:Name="HuangLiDeityRow" Orientation="Horizontal" Margin="0,0,0,6">
                                <Border x:Name="HuangLiXiBadge" Background="#203B82F6" CornerRadius="4" Padding="6,2" Margin="0,0,4,0">
                                    <TextBlock x:Name="HuangLiXiText" FontSize="9" Foreground="#B8C0CC" />
                                </Border>
                                <Border x:Name="HuangLiCaiBadge" Background="#203B82F6" CornerRadius="4" Padding="6,2" Margin="0,0,4,0">
                                    <TextBlock x:Name="HuangLiCaiText" FontSize="9" Foreground="#B8C0CC" />
                                </Border>
                                <Border x:Name="HuangLiFuBadge" Background="#203B82F6" CornerRadius="4" Padding="6,2">
                                    <TextBlock x:Name="HuangLiFuText" FontSize="9" Foreground="#B8C0CC" />
                                </Border>
                            </StackPanel>

                            <TextBlock x:Name="HuangLiTimeTitle" Text="时辰吉凶" FontSize="9" Foreground="#6B7280" Margin="0,0,0,3" />
                            <UniformGrid x:Name="HuangLiTimeGrid" Rows="2" Columns="6" Margin="0,0,0,5" />

                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="HuangLiJiShenLabel" Text="吉神" FontSize="9" Foreground="#6B7280" Margin="0,2,6,0" />
                                <WrapPanel x:Name="HuangLiJiShenWrap" Grid.Column="1" />
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="HuangLiXiongLabel" Text="凶神" FontSize="9" Foreground="#6B7280" Margin="0,2,6,0" />
                                <WrapPanel x:Name="HuangLiXiongWrap" Grid.Column="1" />
                            </Grid>
                            <TextBlock x:Name="HuangLiSecondaryText" FontSize="9" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,0,0,2" />
                            <TextBlock x:Name="HuangLiCurrentTimeText" FontSize="9" Foreground="#3B82F6" TextWrapping="Wrap" Visibility="Collapsed" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock x:Name="YearProgressText" Grid.Row="1" FontSize="11" Foreground="#8B95A5"
                       Margin="0,0,0,6" Visibility="Collapsed" />

            <TextBlock x:Name="CityText" Grid.Row="2" Text="📍 北京"
                       FontSize="11" Foreground="#8B95A5" Margin="0,0,0,4" Visibility="Collapsed" />

            <TextBlock x:Name="WeatherText" Grid.Row="3" Text="☀ 28° 晴  18°~31°"
                       FontSize="12" Foreground="#B8C0CC" Margin="0,0,0,4" Visibility="Collapsed" />

            <TextBlock x:Name="WeatherExtraText" Grid.Row="4" FontSize="11" Foreground="#7E8A9C"
                       Margin="0,0,0,6" Visibility="Collapsed" />

            <TextBlock x:Name="CountdownText" Grid.Row="5" FontSize="12" Foreground="#B8C0CC"
                       Margin="0,0,0,4" Visibility="Collapsed" />

            <TextBlock x:Name="DailyQuoteText" Grid.Row="6" FontSize="11" Foreground="#8B95A5"
                       FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed" />

            <TextBox x:Name="ScratchBox" Grid.Row="7" Height="26" FontSize="11"
                     Background="#252A33" Foreground="#C5D0E0" BorderBrush="#3A4150"
                     Padding="6,3" Margin="0,0,0,8" Cursor="IBeam"
                     Visibility="Collapsed" LostFocus="ScratchBox_LostFocus" KeyDown="ScratchBox_KeyDown" />

            <Border x:Name="DividerBorder" Grid.Row="8" Height="1" Background="#28FFFFFF" Margin="0,0,0,8" />

            <StackPanel Grid.Row="9" Margin="0,0,0,8">
                <TextBlock x:Name="TodoTitleText" Text="今日待办" FontSize="12" Foreground="#8B95A5" Margin="0,0,0,6" />
                <ItemsControl x:Name="TodoList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center"
                                          Tag="{Binding Id}" Click="TodoCheck_Click" />
                                <TextBlock Grid.Column="1" Text="{Binding Display}"
                                           Foreground="{DynamicResource TodoTextBrush}" FontSize="13"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <Button Grid.Column="2" Content="×" Width="22" Height="22" Padding="0"
                                        Margin="4,0,0,0" Tag="{Binding Id}" Click="TodoDelete_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource TodoDeleteBrush}" Cursor="Hand" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="EmptyTodoText" Text="暂无待办" Foreground="#6B7280" FontSize="12" Visibility="Collapsed" />
            </StackPanel>

            <Grid x:Name="CalendarSection" Grid.Row="10" Margin="0,0,0,6" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="CalPrevBtn" Grid.Column="0" Content="‹" Width="22" Height="22" Padding="0"
                            Click="CalPrev_Click" Background="Transparent" BorderThickness="0"
                            Foreground="#8B95A5" Cursor="Hand" FontSize="14" />
                    <TextBlock x:Name="CalendarTitleText" Grid.Column="1" Text="本周 · 万年历"
                               FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Button x:Name="CalWeekModeBtn" Grid.Column="2" Content="周" Width="24" Height="22" Padding="0"
                            Click="CalWeekMode_Click" Background="Transparent" BorderThickness="0"
                            Foreground="#3B82F6" Cursor="Hand" FontSize="10" Margin="4,0,0,0" />
                    <Button x:Name="CalMonthModeBtn" Grid.Column="3" Content="月" Width="24" Height="22" Padding="0"
                            Click="CalMonthMode_Click" Background="Transparent" BorderThickness="0"
                            Foreground="#6B7280" Cursor="Hand" FontSize="10" />
                    <Button x:Name="CalNextBtn" Grid.Column="4" Content="›" Width="22" Height="22" Padding="0"
                            Click="CalNext_Click" Background="Transparent" BorderThickness="0"
                            Foreground="#8B95A5" Cursor="Hand" FontSize="14" Margin="4,0,0,0" />
                </Grid>
                <UniformGrid x:Name="WeekdayHeader" Grid.Row="1" Rows="1" Columns="7" Margin="0,0,0,2" Visibility="Collapsed" />
                <Grid x:Name="CalendarPanel" Grid.Row="2" />
            </Grid>

            <StackPanel Grid.Row="11" Orientation="Horizontal">
                <TextBox x:Name="NewTodoBox" Width="200" Height="30" Background="#252A33"
                         Foreground="#F3F4F6" BorderBrush="#3A4150" Padding="8,4" FontSize="12"
                         Cursor="IBeam" KeyDown="NewTodoBox_KeyDown" />
                <Button x:Name="AddButton" Content="添加" Width="58" Height="30" Margin="8,0,0,0"
                        Click="AddTodo_Click" Background="#3B82F6" Foreground="White"
                        BorderThickness="0" Cursor="Hand" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
