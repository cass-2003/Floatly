<Window x:Class="DeskLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DeskLite"
        Title="Floatly"
        MinWidth="260"
        MinHeight="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        SourceInitialized="Window_SourceInitialized">
    <Window.Resources>
        <SolidColorBrush x:Key="TodoTextBrush" Color="#E8ECF1" />
        <SolidColorBrush x:Key="TodoDeleteBrush" Color="#7E8796" />
        <SolidColorBrush x:Key="TodoCardBgBrush" Color="#18FFFFFF" />
        <SolidColorBrush x:Key="TodoCardBorderBrush" Color="#28FFFFFF" />
        <SolidColorBrush x:Key="TodoTimeBadgeBrush" Color="#223B82F6" />
        <SolidColorBrush x:Key="TodoPinActiveBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="TodoPinInactiveBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="TodoCountBadgeBrush" Color="#223B82F6" />
        <SolidColorBrush x:Key="TodoLinkBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="TodoMutedBrush" Color="#8B95A5" />
        <SolidColorBrush x:Key="TodoEmptyBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="TodoAccentBrush" Color="#3B82F6" />
    </Window.Resources>
    <Border x:Name="MainBorder"
            Background="#E8181C24"
            CornerRadius="12"
            BorderBrush="#40FFFFFF"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="设置..." Click="OpenSettings_Click" />
                <Separator />
                <MenuItem Header="深色主题" Click="ThemeDark_Click" />
                <MenuItem Header="浅色主题" Click="ThemeLight_Click" />
                <Separator />
                <MenuItem Header="不透明 (100%)" Click="Opacity100_Click" />
                <MenuItem Header="轻微透明 (85%)" Click="Opacity85_Click" />
                <MenuItem Header="半透明 (70%)" Click="Opacity70_Click" />
                <MenuItem Header="高透明 (55%)" Click="Opacity55_Click" />
                <Separator />
                <MenuItem Header="周历视图" Click="CalWeekMode_Click" />
                <MenuItem Header="月历视图" Click="CalMonthMode_Click" />
                <MenuItem Header="回到今天" Click="CalToday_Click" />
                <MenuItem Header="跳转日期..." Click="CalJump_Click" />
            </ContextMenu>
        </Border.ContextMenu>
        <Grid>
            <Border x:Name="SkinOverlay" Background="#73000000" CornerRadius="12" Visibility="Collapsed" IsHitTestVisible="False" />
            <Grid x:Name="ContentRoot" Margin="14" PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown" Cursor="SizeAll">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="120" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" x:Name="HeaderBlock" Background="Transparent" Margin="0,0,0,6">
                <StackPanel>
                    <Grid>
                        <TextBlock x:Name="ClockText" Text="14:32:08" FontSize="26" FontWeight="SemiBold" Foreground="#F5F7FA" />
                        <TextBlock x:Name="DateText" Text="周四 6月11日" FontSize="13" Foreground="#B8C0CC"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock x:Name="LunarText" Text="农历五月初六 · 芒种" FontSize="12" Foreground="#C5D0E0" Margin="0,6,0,0" />
                    <TextBlock x:Name="LunarSubText" Text="乙巳年 · 属蛇 · 庚寅日" FontSize="11" Foreground="#7E8A9C" Margin="0,3,0,0" />
                </StackPanel>
            </Border>

            <ScrollViewer x:Name="MainScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,6">
                <StackPanel x:Name="ModuleContentPanel">
                    <Border x:Name="HuangLiPanel" Background="#FF222830" CornerRadius="8" Padding="8,7" Margin="0,0,0,8"
                            ClipToBounds="True" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="HuangLiSolarDate" Grid.Column="0" Text="2026年6月11日" FontSize="12"
                                           Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Button x:Name="HuangLiCollapseBtn" Grid.Column="1" Content="▼" Width="22" Height="22" Padding="0"
                                        Click="HuangLiCollapse_Click" Background="Transparent" BorderThickness="0"
                                        Foreground="#94A3B8" Cursor="Hand" FontSize="10" VerticalAlignment="Center"
                                        ToolTip="收起/展开" />
                            </Grid>

                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="28" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="HuangLiPrevBtn" Grid.Column="0" Content="‹" Width="24" Height="24" Padding="0"
                                        Click="HuangLiPrev_Click" Background="Transparent" BorderThickness="0"
                                        Foreground="#C94133" Cursor="Hand" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
                                <TextBlock x:Name="HuangLiLunarLarge" Grid.Column="1" Text="四月廿六" FontSize="24" FontWeight="Bold"
                                           Foreground="#C94133" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Button x:Name="HuangLiNextBtn" Grid.Column="2" Content="›" Width="24" Height="24" Padding="0"
                                        Click="HuangLiNext_Click" Background="Transparent" BorderThickness="0"
                                        Foreground="#C94133" Cursor="Hand" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
                            </Grid>

                            <StackPanel x:Name="HuangLiDetailsPanel">
                            <TextBlock x:Name="HuangLiMetaLine" Text="丙午年 甲午月 丙辰日 [属马] 周四 第24周"
                                       FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap" HorizontalAlignment="Center"
                                       TextAlignment="Center" Margin="0,0,0,8" />

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border x:Name="HuangLiYiCircle" Width="18" Height="18" CornerRadius="9"
                                                Background="#C94133" VerticalAlignment="Top" Margin="0,1,6,0">
                                            <TextBlock x:Name="HuangLiYiCircleText" Text="宜" FontSize="10" FontWeight="SemiBold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock x:Name="HuangLiYiText" FontSize="12" Foreground="#F5F7FA" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border x:Name="HuangLiJiCircle" Width="18" Height="18" CornerRadius="9"
                                                Background="#2D2D2D" VerticalAlignment="Top" Margin="0,1,6,0">
                                            <TextBlock x:Name="HuangLiJiCircleText" Text="忌" FontSize="10" FontWeight="SemiBold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock x:Name="HuangLiJiText" FontSize="12" Foreground="#F5F7FA" TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <Border x:Name="HuangLiMetaGridBorder" BorderBrush="#30FFFFFF" BorderThickness="1" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="HuangLiMetaWuXing" Grid.Column="0" BorderBrush="#30FFFFFF" BorderThickness="0,0,1,0" Padding="5,4">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock x:Name="HuangLiWuXingLabel" Text="五行" FontSize="10" Foreground="#B88A5A" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="HuangLiWuXingVal" FontSize="11" Foreground="#B8C0CC" Margin="0,2,0,0"
                                                       HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="HuangLiMetaChong" Grid.Column="1" BorderBrush="#30FFFFFF" BorderThickness="0,0,1,0" Padding="5,4">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock x:Name="HuangLiChongLabel" Text="冲煞" FontSize="10" Foreground="#B88A5A" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="HuangLiChongVal" FontSize="11" Foreground="#B8C0CC" Margin="0,2,0,0"
                                                       HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="HuangLiMetaZhi" Grid.Column="2" Padding="5,4">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock x:Name="HuangLiZhiLabel" Text="值神" FontSize="10" Foreground="#B88A5A" HorizontalAlignment="Center" />
                                            <TextBlock x:Name="HuangLiZhiVal" FontSize="11" Foreground="#B8C0CC" Margin="0,2,0,0"
                                                       HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border x:Name="HuangLiTimeStripBorder" BorderBrush="#30FFFFFF" BorderThickness="1" Margin="0,0,0,6" Padding="2,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="HuangLiTimeTitle" Grid.Column="0" Text="时辰吉凶" FontSize="10" Foreground="#B88A5A"
                                               TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" LineHeight="12" />
                                    <UniformGrid x:Name="HuangLiTimeStrip" Grid.Column="1" Columns="12" />
                                </Grid>
                            </Border>

                            <Border x:Name="HuangLiDetailBorder" BorderBrush="#30FFFFFF" BorderThickness="1" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="46" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border x:Name="HuangLiJianCell" Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                                            BorderBrush="#30FFFFFF" BorderThickness="0,0,1,0" Padding="4,4">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="HuangLiJianLabel" Text="建除十二神" FontSize="10" Foreground="#B88A5A"
                                                       TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                                            <TextBlock x:Name="HuangLiJianVal" FontSize="11" Foreground="#B8C0CC" Margin="0,3,0,0"
                                                       TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <Grid Grid.Row="0" Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="HuangLiJiShenInner" Grid.Column="0" BorderBrush="#30FFFFFF" BorderThickness="0,0,1,1" Padding="4,4">
                                            <StackPanel>
                                                <TextBlock x:Name="HuangLiJiShenLabel" Text="吉神宜趋" FontSize="10" Foreground="#B88A5A" />
                                                <TextBlock x:Name="HuangLiJiShenVal" FontSize="10" Foreground="#B8C0CC" Margin="0,2,0,0"
                                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                        <Border x:Name="HuangLiTaiShenInner" Grid.Column="1" BorderBrush="#30FFFFFF" BorderThickness="0,0,1,1" Padding="4,4">
                                            <StackPanel>
                                                <TextBlock x:Name="HuangLiTaiShenLabel" Text="今日胎神" FontSize="10" Foreground="#B88A5A" />
                                                <TextBlock x:Name="HuangLiTaiShenVal" FontSize="10" Foreground="#B8C0CC" Margin="0,2,0,0"
                                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                        <Border x:Name="HuangLiXiongInner" Grid.Column="2" BorderBrush="#30FFFFFF" BorderThickness="0,0,0,1" Padding="4,4">
                                            <StackPanel>
                                                <TextBlock x:Name="HuangLiXiongLabel" Text="凶神宜忌" FontSize="10" Foreground="#B88A5A" />
                                                <TextBlock x:Name="HuangLiXiongVal" FontSize="10" Foreground="#B8C0CC" Margin="0,2,0,0"
                                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border x:Name="HuangLiPengZuCell" Grid.Row="1" Grid.Column="1" Padding="4,4">
                                        <StackPanel>
                                            <TextBlock x:Name="HuangLiPengZuLabel" Text="彭祖百忌" FontSize="10" Foreground="#B88A5A" />
                                            <TextBlock x:Name="HuangLiPengZuVal" FontSize="10" Foreground="#B8C0CC" Margin="0,2,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="HuangLiXiuCell" Grid.Row="0" Grid.Column="2" Grid.RowSpan="2"
                                            BorderBrush="#30FFFFFF" BorderThickness="1,0,0,0" Padding="4,4">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="HuangLiXiuLabel" Text="二十八星宿" FontSize="10" Foreground="#B88A5A"
                                                       TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                                            <TextBlock x:Name="HuangLiXiuVal" FontSize="10" Foreground="#B8C0CC" Margin="0,3,0,0"
                                                       TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border x:Name="HuangLiCurrentDivider" Height="1" Background="#30FFFFFF" Margin="0,0,0,6" />

                            <StackPanel x:Name="HuangLiCurrentCard" Visibility="Collapsed">
                                <TextBlock x:Name="HuangLiCurrentTitle" Text="当前时辰" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#F5F7FA" Margin="0,0,0,6" />

                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="HuangLiCurrentZhiCircle" Width="40" Height="40" CornerRadius="20"
                                            Background="#C94133" VerticalAlignment="Top">
                                        <TextBlock x:Name="HuangLiCurrentZhi" Text="午" FontSize="20" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="8,0,4,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="HuangLiCurrentSummary" FontSize="12" Foreground="#F5F7FA" TextWrapping="Wrap" />
                                        <TextBlock x:Name="HuangLiCurrentDirections" FontSize="10" Foreground="#94A3B8" Margin="0,2,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Border x:Name="HuangLiCurrentLuckBadge" Grid.Column="2" Width="20" Height="20" CornerRadius="10"
                                            Background="#2D2D2D" VerticalAlignment="Top">
                                        <TextBlock x:Name="HuangLiCurrentLuckText" Text="凶" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <Border x:Name="HuangLiCurrentYiCircle" Width="16" Height="16" CornerRadius="8"
                                            Background="#C94133" VerticalAlignment="Top" Margin="0,1,5,0">
                                        <TextBlock x:Name="HuangLiCurrentYiCircleText" Text="宜" FontSize="9" FontWeight="SemiBold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock x:Name="HuangLiCurrentYiText" FontSize="11" Foreground="#B8C0CC" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border x:Name="HuangLiCurrentJiCircle" Width="16" Height="16" CornerRadius="8"
                                            Background="#2D2D2D" VerticalAlignment="Top" Margin="0,1,5,0">
                                        <TextBlock x:Name="HuangLiCurrentJiCircleText" Text="忌" FontSize="9" FontWeight="SemiBold" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock x:Name="HuangLiCurrentJiText" FontSize="11" Foreground="#B8C0CC" TextWrapping="Wrap" />
                                </StackPanel>

                                <Border x:Name="HuangLiMoreBtn" Background="#18FFFFFF" CornerRadius="4" Padding="6,4"
                                        HorizontalAlignment="Stretch" Cursor="Hand" MouseLeftButtonUp="HuangLiMore_Click">
                                    <TextBlock x:Name="HuangLiMoreText" Text="查看更多 ›" FontSize="11" Foreground="#94A3B8"
                                               HorizontalAlignment="Center" />
                                </Border>
                            </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel x:Name="YearProgressPanel" Margin="0,0,0,8" Visibility="Collapsed">
                        <Grid Margin="0,0,0,4">
                            <TextBlock x:Name="YearProgressLabel" Text="2026 年进度" FontSize="11"
                                       Foreground="#8B95A5" VerticalAlignment="Center" />
                            <TextBlock x:Name="YearProgressPercent" Text="45.2%" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#F5F7FA" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                        <Border x:Name="YearProgressTrack" Height="7" CornerRadius="3.5"
                                Background="#28FFFFFF" ClipToBounds="True" Margin="0,0,0,4">
                            <Border x:Name="YearProgressFill" HorizontalAlignment="Left" CornerRadius="3.5"
                                    Background="#3B82F6" Width="0" />
                        </Border>
                        <TextBlock x:Name="YearProgressDetail" Text="已过 162 天 / 全年 366 天"
                                   FontSize="10" Foreground="#7E8A9C" />
                    </StackPanel>

                    <StackPanel x:Name="WeatherPanel">
                        <TextBlock x:Name="CityText" Text="📍 北京"
                                   FontSize="11" Foreground="#8B95A5" Margin="0,0,0,4" Visibility="Collapsed" />

                        <TextBlock x:Name="WeatherText" Text="☀ 28° 晴  18°~31°"
                                   FontSize="12" Foreground="#B8C0CC" Margin="0,0,0,4" Visibility="Collapsed" />

                        <TextBlock x:Name="WeatherExtraText" FontSize="11" Foreground="#7E8A9C"
                                   Margin="0,0,0,6" Visibility="Collapsed" />
                    </StackPanel>

                    <StackPanel x:Name="CountdownPanel" Margin="0,0,0,8" Visibility="Collapsed">
                        <Grid Margin="0,0,0,4">
                            <TextBlock x:Name="CountdownLabel" Text="距离国庆还有" FontSize="11"
                                       Foreground="#8B95A5" VerticalAlignment="Center" />
                            <TextBlock x:Name="CountdownDays" Text="112 天" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#B8C0CC" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                        <Border x:Name="CountdownTrack" Height="7" CornerRadius="3.5"
                                Background="#28FFFFFF" ClipToBounds="True" Margin="0,0,0,4">
                            <Border x:Name="CountdownFill" HorizontalAlignment="Left" CornerRadius="3.5"
                                    Background="#3B82F6" Width="0" />
                        </Border>
                        <TextBlock x:Name="CountdownHint" Text="越接近目标，进度条越满"
                                   FontSize="10" Foreground="#7E8A9C" />
                    </StackPanel>

                    <Border x:Name="PomodoroPanel" Background="#18FFFFFF" CornerRadius="8" Padding="10,8"
                            Margin="0,0,0,8" ClipToBounds="True" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock x:Name="PomodoroPhaseText" Text="番茄钟" FontSize="11"
                                           Foreground="#8B95A5" VerticalAlignment="Center" />
                                <TextBlock x:Name="PomodoroSessionText" Text="第 0 个番茄" FontSize="10"
                                           Foreground="#7E8A9C" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock x:Name="PomodoroCountdownText" Text="25:00" FontSize="28" FontWeight="SemiBold"
                                       Foreground="#F5F7FA" HorizontalAlignment="Center" Margin="0,0,0,6" />
                            <Border x:Name="PomodoroTrack" Height="7" CornerRadius="3.5"
                                    Background="#28FFFFFF" ClipToBounds="True" Margin="0,0,0,8">
                                <Border x:Name="PomodoroFill" HorizontalAlignment="Left" CornerRadius="3.5"
                                        Background="#F97316" Width="0" />
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="PomodoroStartBtn" Content="开始" Width="64" Height="26" Padding="0"
                                        Click="PomodoroStart_Click" Background="#3B82F6" Foreground="White"
                                        BorderThickness="0" Cursor="Hand" FontSize="11" />
                                <Button x:Name="PomodoroResetBtn" Content="重置" Width="52" Height="26" Padding="0"
                                        Margin="8,0,0,0" Click="PomodoroReset_Click"
                                        Background="Transparent" Foreground="#94A3B8"
                                        BorderBrush="#3A4150" BorderThickness="1" Cursor="Hand" FontSize="11" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="DailyQuoteText" FontSize="11" Foreground="#8B95A5"
                               FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed" />

                    <Border x:Name="ScratchPanel" Margin="0,0,0,8" Padding="0" Visibility="Collapsed"
                            Background="Transparent" Cursor="Hand" MouseLeftButtonUp="ScratchPanel_Click">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="ScratchTitleText" Text="速记便签" FontSize="12"
                                               Foreground="#8B95A5" VerticalAlignment="Center" />
                                    <Border x:Name="ScratchCountBadge" CornerRadius="8" Padding="6,1" Margin="6,0,0,0"
                                            Background="#203B82F6" VerticalAlignment="Center">
                                        <TextBlock x:Name="ScratchCountText" Text="0" FontSize="10"
                                                   Foreground="#3B82F6" FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="ScratchExpandText" Text="展开" FontSize="11" Foreground="#94A3B8"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"
                                           MouseLeftButtonUp="ScratchExpand_Click" />
                            </Grid>
                            <Border x:Name="ScratchPreviewCard" CornerRadius="8" Padding="8,6"
                                    Background="#282F30" BorderBrush="#3A4150" BorderThickness="1"
                                    MouseLeftButtonUp="ScratchExpand_Click">
                                <StackPanel>
                                    <TextBlock x:Name="ScratchPreviewTitle" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#C5D0E0" TextTrimming="CharacterEllipsis" Margin="0,0,0,2" />
                                    <TextBlock x:Name="ScratchPreviewContent" FontSize="10" Foreground="#8B95A5"
                                               TextWrapping="Wrap" MaxHeight="32" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="ScratchEmptyText" Text="点击展开 · 新建便签" FontSize="11"
                                       Foreground="#6B7280" Margin="0,4,0,0" Visibility="Collapsed"
                                       MouseLeftButtonUp="ScratchExpand_Click" Cursor="Hand" />
                        </StackPanel>
                    </Border>

                    <StackPanel x:Name="TodoPanel">
                        <Border x:Name="DividerBorder" Height="1" Background="#28FFFFFF" Margin="0,0,0,8" />

                        <Grid Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="TodoTitleText" Text="今日待办" FontSize="12"
                                           Foreground="#8B95A5" VerticalAlignment="Center" />
                                <Border x:Name="TodoCountBadge" CornerRadius="8" Padding="6,1" Margin="6,0,0,0"
                                        Background="{DynamicResource TodoCountBadgeBrush}" VerticalAlignment="Center">
                                    <TextBlock x:Name="TodoCountText" Text="0/0" FontSize="10"
                                               Foreground="{DynamicResource TodoAccentBrush}" FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <ItemsControl x:Name="TodoList" Margin="0,0,0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource TodoCardBgBrush}"
                                            BorderBrush="{DynamicResource TodoCardBorderBrush}"
                                            BorderThickness="1" CornerRadius="8"
                                            Padding="8,6" Margin="0,0,0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <local:CircleCheckBox Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center"
                                                                  TagId="{Binding Id}" Click="TodoCheck_Click" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{DynamicResource TodoTimeBadgeBrush}"
                                                            CornerRadius="4" Padding="4,1" Margin="0,0,6,0" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasTime}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Time}" FontSize="10"
                                                                   Foreground="{DynamicResource TodoAccentBrush}"
                                                                   FontWeight="SemiBold" ToolTip="提醒时间" />
                                                    </Border>
                                                    <Border Background="#22F59E0B" CornerRadius="4" Padding="4,1" Margin="0,0,6,0"
                                                            VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasDueDate}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding DueDateLabel}" FontSize="10"
                                                                   Foreground="#F59E0B" FontWeight="SemiBold" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TodoTextBrush}"
                                                               FontSize="13" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                               Tag="{Binding Id}" MouseLeftButtonDown="TodoTitle_DoubleClick"
                                                               Cursor="Hand" ToolTip="双击编辑" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="{Binding PinIcon}" Width="22" Height="22" Padding="0"
                                                        Tag="{Binding Id}" Click="TodoPin_Click"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        ToolTip="置顶" FontSize="12">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Foreground" Value="{DynamicResource TodoPinInactiveBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Pinned}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TodoPinActiveBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="✎" Width="22" Height="22" Padding="0" Margin="0,0,0,0"
                                                        Tag="{Binding Id}" Click="TodoEdit_Click"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Foreground="{DynamicResource TodoMutedBrush}" ToolTip="编辑" FontSize="11" />
                                                <Button Content="×" Width="22" Height="22" Padding="0"
                                                        Tag="{Binding Id}" Click="TodoDelete_Click"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Foreground="{DynamicResource TodoDeleteBrush}" ToolTip="删除" FontSize="14" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border x:Name="EmptyTodoPanel" Background="{DynamicResource TodoCardBgBrush}"
                                BorderBrush="{DynamicResource TodoCardBorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="12,10" Margin="0,0,0,6" Visibility="Collapsed">
                            <TextBlock x:Name="EmptyTodoText" Text="暂无待办，在下方添加一条吧 ✨"
                                       Foreground="{DynamicResource TodoEmptyBrush}" FontSize="12"
                                       TextAlignment="Center" TextWrapping="Wrap" />
                        </Border>

                        <Border x:Name="TodoOverflowBtn" Background="#18FFFFFF" CornerRadius="6" Padding="6,4"
                                Margin="0,0,0,4" Cursor="Hand" MouseLeftButtonUp="TodoViewAll_Click"
                                Visibility="Collapsed">
                            <TextBlock x:Name="TodoOverflowText" Text="还有 0 条未显示 ›" FontSize="11"
                                       Foreground="{DynamicResource TodoLinkBrush}" HorizontalAlignment="Center" />
                        </Border>

                        <Border x:Name="TodoViewAllBtn" Background="Transparent" CornerRadius="4" Padding="2,2"
                                Cursor="Hand" MouseLeftButtonUp="TodoViewAll_Click">
                            <TextBlock x:Name="TodoViewAllText" Text="查看全部 ›" FontSize="11"
                                       Foreground="{DynamicResource TodoLinkBrush}" HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="CalendarSection" Grid.Row="2" Margin="0,0,0,6" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="CalPrevBtn" Grid.Column="0" Content="‹" Width="22" Height="22" Padding="0"
                            Click="CalPrev_Click" Background="Transparent" BorderThickness="0"
                            Foreground="#8B95A5" Cursor="Hand" FontSize="14" />
                    <TextBlock x:Name="CalendarTitleText" Grid.Column="1" Text="本周 · 万年历"
                               FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Button x:Name="CalWeekModeBtn" Grid.Column="2" Content="周" Width="24" Height="22" Padding="0"
                            Click="CalWeekMode_Click" Background="Transparent" BorderThickness="0"
                            Foreground="#3B82F6" Cursor="Hand" FontSize="10" Margin="4,0,0,0" />
                    <Button x:Name="CalMonthModeBtn" Grid.Column="3" Content="月" Width="24" Height="22" Padding="0"
                            Click="CalMonthMode_Click" Background="Transparent" BorderThickness="0"
                            Foreground="#6B7280" Cursor="Hand" FontSize="10" />
                    <Button x:Name="CalNextBtn" Grid.Column="4" Content="›" Width="22" Height="22" Padding="0"
                            Click="CalNext_Click" Background="Transparent" BorderThickness="0"
                            Foreground="#8B95A5" Cursor="Hand" FontSize="14" Margin="4,0,0,0" />
                </Grid>
                <UniformGrid x:Name="WeekdayHeader" Grid.Row="1" Rows="1" Columns="7" Margin="0,0,0,2" Visibility="Collapsed" />
                <Grid x:Name="CalendarPanel" Grid.Row="2" />
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal">
                <TextBox x:Name="NewTodoBox" Width="200" Height="30" Background="#252A33"
                         Foreground="#F3F4F6" BorderBrush="#3A4150" Padding="8,4" FontSize="12"
                         Cursor="IBeam" KeyDown="NewTodoBox_KeyDown" GotFocus="NewTodoBox_GotFocus" LostFocus="NewTodoBox_LostFocus" />
                <Button x:Name="AddButton" Content="添加" Width="58" Height="30" Margin="8,0,0,0"
                        Click="AddTodo_Click" Background="#3B82F6" Foreground="White"
                        BorderThickness="0" Cursor="Hand" />
            </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
