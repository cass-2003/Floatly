<Window x:Class="DeskLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DeskLite"
        Title="Floatly"
        MinWidth="360"
        MinHeight="420"
        Width="420"
        Height="620"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Topmost="True"
        SourceInitialized="Window_SourceInitialized">
    <Window.Resources>
        <SolidColorBrush x:Key="TodoTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TodoDeleteBrush" Color="#7E8796" />
        <SolidColorBrush x:Key="TodoCardBgBrush" Color="#18FFFFFF" />
        <SolidColorBrush x:Key="TodoCardBorderBrush" Color="#0DFFFFFF" />
        <SolidColorBrush x:Key="TodoTimeBadgeBrush" Color="#225C8DFF" />
        <SolidColorBrush x:Key="TodoPinActiveBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="TodoPinInactiveBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="TodoCountBadgeBrush" Color="#225C8DFF" />
        <SolidColorBrush x:Key="TodoLinkBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="TodoMutedBrush" Color="#8B95A5" />
        <SolidColorBrush x:Key="TodoEmptyBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="TodoAccentBrush" Color="#5C8DFF" />

        <Style x:Key="FloatlyCard" TargetType="Border">
            <Setter Property="Background" Value="#F21E2028" />
            <Setter Property="BorderBrush" Value="#14FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
        <Style x:Key="HeaderIconBtn" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#A6FFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="HeroCard" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="ClipToBounds" Value="False" />
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#A6FFFFFF" />
        </Style>
        <Style x:Key="ResizeGripThumb" TargetType="{x:Type Thumb}">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder"
            Background="#F0131722"
            CornerRadius="16"
            BorderBrush="#14FFFFFF"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="设置..." Click="OpenSettings_Click" />
                <Separator />
                <MenuItem Header="深色主题" Click="ThemeDark_Click" />
                <MenuItem Header="浅色主题" Click="ThemeLight_Click" />
                <Separator />
                <MenuItem Header="不透明 (100%)" Click="Opacity100_Click" />
                <MenuItem Header="轻微透明 (85%)" Click="Opacity85_Click" />
                <MenuItem Header="半透明 (70%)" Click="Opacity70_Click" />
                <MenuItem Header="高透明 (55%)" Click="Opacity55_Click" />
                <Separator />
                <MenuItem Header="周历视图" Click="CalWeekMode_Click" />
                <MenuItem Header="月历视图" Click="CalMonthMode_Click" />
                <MenuItem Header="回到今天" Click="CalToday_Click" />
                <MenuItem Header="跳转日期..." Click="CalJump_Click" />
            </ContextMenu>
        </Border.ContextMenu>
        <Grid>
            <MediaElement x:Name="SkinVideo"
                          LoadedBehavior="Manual" UnloadedBehavior="Stop" IsMuted="True" Volume="0"
                          Stretch="UniformToFill" Visibility="Collapsed" IsHitTestVisible="False"
                          MediaEnded="SkinVideo_MediaEnded" Loaded="SkinVideo_Loaded" />
            <Border x:Name="SkinOverlay" Background="#8C000000" CornerRadius="16" Visibility="Collapsed" IsHitTestVisible="False" />

            <Border x:Name="ContentBackdrop" Background="#CC0D0F14" CornerRadius="14" Margin="8"
                    IsHitTestVisible="False" Visibility="Visible" />

            <Grid x:Name="ContentRoot" Margin="22,22,22,16" PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown" Cursor="SizeAll">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="200" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Hero Header (fixed above scroll - Row 0) -->
                <Border Grid.Row="0" x:Name="HeaderBlock" Style="{StaticResource HeroCard}" Margin="0,0,0,8">
                    <StackPanel ClipToBounds="False">
                        <!-- Row 1: clock | weather | controls -->
                        <Grid VerticalAlignment="Stretch" ClipToBounds="False">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: time + date + city (no lunar; row 2 strip handles huangli) -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Top" ClipToBounds="False">
                                <Grid VerticalAlignment="Top" ClipToBounds="False">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="ClockText" Grid.Column="0" Text="15:03" FontSize="40" FontWeight="Medium"
                                               Foreground="#FFFFFF" LineHeight="42" LineStackingStrategy="BlockLineHeight"
                                               TextTrimming="None" />
                                    <TextBlock x:Name="ClockSecondsText" Grid.Column="1" Text="54" FontSize="14" FontWeight="Medium"
                                               Foreground="#A6FFFFFF" VerticalAlignment="Bottom" Margin="2,0,0,4"
                                               TextTrimming="None" Visibility="Visible" />
                                </Grid>
                                <TextBlock x:Name="DateText" Text="2026年6月1日 周四" FontSize="11"
                                           Foreground="#A6FFFFFF" Margin="0,2,0,0" TextTrimming="None" />
                                <TextBlock x:Name="CityText" Text="📍 东京 Tokyo" FontSize="11" Foreground="#8B95A5"
                                           Margin="0,2,0,0" Visibility="Collapsed" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="LunarText" Text="农历五月初六 · 芒种" FontSize="10" Foreground="#8B95A5"
                                           Margin="0,2,0,0" Visibility="Collapsed" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="LunarSubText" Text="乙巳年 · 属蛇" FontSize="9" Foreground="#6B7280"
                                           Margin="0,1,0,0" Visibility="Collapsed" TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <!-- Center: weather -->
                            <StackPanel x:Name="WeatherPanel" Grid.Column="1" VerticalAlignment="Bottom"
                                        HorizontalAlignment="Center" Margin="8,0,8,0" Visibility="Collapsed"
                                        ClipToBounds="False">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                    <Image x:Name="WeatherIconImage" Width="42" Height="42" VerticalAlignment="Center"
                                           Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality" />
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="WeatherTempText" Grid.Column="0" Text="25°" FontSize="30" FontWeight="Medium"
                                                   Foreground="#FFFFFF" VerticalAlignment="Center" />
                                        <TextBlock x:Name="WeatherDescText" Grid.Column="1" Text="多云" FontSize="11" FontWeight="Medium"
                                                   Foreground="#FFFFFF" VerticalAlignment="Bottom" Margin="5,0,0,4"
                                                   Visibility="Visible" />
                                    </Grid>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0"
                                            ClipToBounds="False">
                                    <TextBlock x:Name="WeatherRangeText" Text="17° ~ 26°" FontSize="11"
                                               Foreground="#8B95A5" TextTrimming="None" />
                                    <TextBlock x:Name="WeatherFeelsText" Text="体感 26°" FontSize="11"
                                               Foreground="#8B95A5" Margin="8,0,0,0" TextTrimming="None" />
                                </StackPanel>
                                <!-- Legacy (hidden) -->
                                <TextBlock x:Name="WeatherIconText" Visibility="Collapsed" />
                                <TextBlock x:Name="WeatherText" Visibility="Collapsed" />
                                <TextBlock x:Name="WeatherExtraText" Visibility="Collapsed" />
                            </StackPanel>

                            <!-- Right: toolbar + sun/tomorrow -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right"
                                        Margin="0,0,-4,0" ClipToBounds="False">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="PinBtn" Content="📌" Style="{StaticResource HeaderIconBtn}"
                                            Click="PinBtn_Click" ToolTip="置顶" />
                                    <Button x:Name="SettingsBtn" Content="⚙" Style="{StaticResource HeaderIconBtn}"
                                            Margin="2,0,0,0" Click="OpenSettings_Click" ToolTip="设置" />
                                    <Button x:Name="MoreBtn" Content="⋯" Style="{StaticResource HeaderIconBtn}"
                                            Margin="2,0,0,0" Click="MoreBtn_Click" ToolTip="更多" FontSize="16" />
                                </StackPanel>
                                <StackPanel x:Name="SunriseRow" Orientation="Horizontal" HorizontalAlignment="Right"
                                            Margin="0,8,0,0" Visibility="Collapsed">
                                    <Image x:Name="SunriseIconImage" Width="14" Height="14" VerticalAlignment="Center"
                                           Margin="0,0,4,0" RenderOptions.BitmapScalingMode="HighQuality" />
                                    <TextBlock x:Name="SunriseLineText" Text="日出 04:24" FontSize="11" Foreground="#8B95A5"
                                               VerticalAlignment="Center" TextTrimming="None" />
                                </StackPanel>
                                <StackPanel x:Name="SunsetRow" Orientation="Horizontal" HorizontalAlignment="Right"
                                            Margin="0,2,0,0" Visibility="Collapsed">
                                    <Image x:Name="SunsetIconImage" Width="14" Height="14" VerticalAlignment="Center"
                                           Margin="0,0,4,0" RenderOptions.BitmapScalingMode="HighQuality" />
                                    <TextBlock x:Name="SunsetLineText" Text="日落 18:56" FontSize="11" Foreground="#8B95A5"
                                               VerticalAlignment="Center" TextTrimming="None" />
                                </StackPanel>
                                <StackPanel x:Name="TomorrowRow" Orientation="Horizontal" HorizontalAlignment="Right"
                                            Margin="0,4,-8,0" Visibility="Collapsed" ClipToBounds="False">
                                    <Image x:Name="TomorrowIconImage" Width="13" Height="13" VerticalAlignment="Center"
                                           Margin="0,0,3,0" RenderOptions.BitmapScalingMode="HighQuality" />
                                    <TextBlock x:Name="TomorrowLineText" Text="明天 19° ~ 28°" FontSize="9"
                                               Foreground="#8B95A5" VerticalAlignment="Center" TextTrimming="None" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Row 2: lunar / huangli compact strip (full width, below row 1) -->
                        <Border x:Name="HeroLunarStrip" Visibility="Collapsed" BorderBrush="#14FFFFFF"
                                BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📅" FontSize="14" VerticalAlignment="Top" Margin="0,0,8,0" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="农历 " FontSize="11" Foreground="#8B95A5" VerticalAlignment="Center" />
                                        <TextBlock x:Name="HuangLiLunarLarge" Text="四月廿六" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#FF8A72" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock x:Name="HuangLiMetaLineStrip" Text="丙午年 甲午月 戊申日" FontSize="10"
                                               Foreground="#8B95A5" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <WrapPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <Border x:Name="HuangLiYiCircle" CornerRadius="4" Padding="4,2" Margin="0,0,4,0" Background="#2255D38A">
                                            <TextBlock x:Name="HuangLiYiCircleText" Text="宜" FontSize="9" FontWeight="SemiBold" Foreground="#55D38A" />
                                        </Border>
                                        <TextBlock x:Name="HuangLiYiText" FontSize="10" Foreground="#A6FFFFFF" MaxWidth="88"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border x:Name="HuangLiJiCircle" CornerRadius="4" Padding="4,2" Margin="0,0,4,0" Background="#22FF8A72">
                                            <TextBlock x:Name="HuangLiJiCircleText" Text="忌" FontSize="9" FontWeight="SemiBold" Foreground="#FF8A72" />
                                        </Border>
                                        <TextBlock x:Name="HuangLiJiText" FontSize="10" Foreground="#A6FFFFFF" MaxWidth="72"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,4,0" />
                                        <Button x:Name="HuangLiCollapseBtn" Content="⌄" Width="22" Height="22" Padding="0"
                                                Click="HuangLiCollapse_Click" Background="Transparent" BorderThickness="0"
                                                Foreground="#94A3B8" Cursor="Hand" FontSize="12" ToolTip="展开/收起" VerticalAlignment="Center" />
                                    </StackPanel>
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Main modules -->
                <ScrollViewer x:Name="MainScrollViewer" Grid.Row="1"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              ClipToBounds="True" Padding="0,0,2,4">
                    <StackPanel x:Name="ModuleContentPanel">
                        <!-- HuangLi expanded details (compact strip lives in hero) -->
                        <Border x:Name="HuangLiPanel" Style="{StaticResource FloatlyCard}" Margin="0,0,0,10" Visibility="Collapsed">
                            <StackPanel>
                                <StackPanel x:Name="HuangLiDetailsPanel">
                                    <TextBlock x:Name="HuangLiSolarDate" Text="2026年6月1日" FontSize="11" Foreground="#8B95A5" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" /><ColumnDefinition Width="*" /><ColumnDefinition Width="28" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="HuangLiPrevBtn" Grid.Column="0" Content="‹" Width="24" Height="24" Padding="0"
                                                Click="HuangLiPrev_Click" Background="Transparent" BorderThickness="0"
                                                Foreground="#FF8A72" Cursor="Hand" FontSize="18" FontWeight="Bold" />
                                        <TextBlock x:Name="HuangLiDetailNavLine" Grid.Column="1" Text="丙午日 甲午时" FontSize="10"
                                                   Foreground="#8B95A5" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                                        <Button x:Name="HuangLiNextBtn" Grid.Column="2" Content="›" Width="24" Height="24" Padding="0"
                                                Click="HuangLiNext_Click" Background="Transparent" BorderThickness="0"
                                                Foreground="#FF8A72" Cursor="Hand" FontSize="18" FontWeight="Bold" />
                                    </Grid>
                                    <Border x:Name="HuangLiMetaGridBorder" BorderBrush="#0DFFFFFF" BorderThickness="1" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="HuangLiMetaWuXing" Grid.Column="0" BorderBrush="#0DFFFFFF" BorderThickness="0,0,1,0" Padding="4,3">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock x:Name="HuangLiWuXingLabel" Text="五行" FontSize="9" Foreground="#B88A5A" HorizontalAlignment="Center" />
                                                    <TextBlock x:Name="HuangLiWuXingVal" FontSize="10" Foreground="#A6FFFFFF" Margin="0,1,0,0" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Border>
                                            <Border x:Name="HuangLiMetaChong" Grid.Column="1" BorderBrush="#0DFFFFFF" BorderThickness="0,0,1,0" Padding="4,3">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock x:Name="HuangLiChongLabel" Text="冲煞" FontSize="9" Foreground="#B88A5A" HorizontalAlignment="Center" />
                                                    <TextBlock x:Name="HuangLiChongVal" FontSize="10" Foreground="#A6FFFFFF" Margin="0,1,0,0" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Border>
                                            <Border x:Name="HuangLiMetaZhi" Grid.Column="2" Padding="4,3">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock x:Name="HuangLiZhiLabel" Text="值神" FontSize="9" Foreground="#B88A5A" HorizontalAlignment="Center" />
                                                    <TextBlock x:Name="HuangLiZhiVal" FontSize="10" Foreground="#A6FFFFFF" Margin="0,1,0,0" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <Border x:Name="HuangLiTimeStripBorder" BorderBrush="#0DFFFFFF" BorderThickness="1" Margin="0,0,0,4" Padding="2,3">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="20" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <TextBlock x:Name="HuangLiTimeTitle" Grid.Column="0" Text="时辰" FontSize="9" Foreground="#B88A5A" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            <UniformGrid x:Name="HuangLiTimeStrip" Grid.Column="1" Columns="12" />
                                        </Grid>
                                    </Border>
                                    <Border x:Name="HuangLiDetailBorder" BorderBrush="#0DFFFFFF" BorderThickness="1" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="40" /><ColumnDefinition Width="*" /><ColumnDefinition Width="40" /></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                            <Border x:Name="HuangLiJianCell" Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" BorderBrush="#0DFFFFFF" BorderThickness="0,0,1,0" Padding="3,3">
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock x:Name="HuangLiJianLabel" Text="建除" FontSize="9" Foreground="#B88A5A" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                                                    <TextBlock x:Name="HuangLiJianVal" FontSize="10" Foreground="#A6FFFFFF" Margin="0,2,0,0" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <Grid Grid.Row="0" Grid.Column="1">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                <Border x:Name="HuangLiJiShenInner" Grid.Column="0" BorderBrush="#0DFFFFFF" BorderThickness="0,0,1,1" Padding="3,3">
                                                    <StackPanel>
                                                        <TextBlock x:Name="HuangLiJiShenLabel" Text="吉神" FontSize="9" Foreground="#B88A5A" />
                                                        <TextBlock x:Name="HuangLiJiShenVal" FontSize="9" Foreground="#A6FFFFFF" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                                <Border x:Name="HuangLiTaiShenInner" Grid.Column="1" BorderBrush="#0DFFFFFF" BorderThickness="0,0,1,1" Padding="3,3">
                                                    <StackPanel>
                                                        <TextBlock x:Name="HuangLiTaiShenLabel" Text="胎神" FontSize="9" Foreground="#B88A5A" />
                                                        <TextBlock x:Name="HuangLiTaiShenVal" FontSize="9" Foreground="#A6FFFFFF" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                                <Border x:Name="HuangLiXiongInner" Grid.Column="2" BorderBrush="#0DFFFFFF" BorderThickness="0,0,0,1" Padding="3,3">
                                                    <StackPanel>
                                                        <TextBlock x:Name="HuangLiXiongLabel" Text="凶神" FontSize="9" Foreground="#B88A5A" />
                                                        <TextBlock x:Name="HuangLiXiongVal" FontSize="9" Foreground="#A6FFFFFF" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                            <Border x:Name="HuangLiPengZuCell" Grid.Row="1" Grid.Column="1" Padding="3,3">
                                                <StackPanel>
                                                    <TextBlock x:Name="HuangLiPengZuLabel" Text="彭祖百忌" FontSize="9" Foreground="#B88A5A" />
                                                    <TextBlock x:Name="HuangLiPengZuVal" FontSize="9" Foreground="#A6FFFFFF" Margin="0,1,0,0" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border x:Name="HuangLiXiuCell" Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" BorderBrush="#0DFFFFFF" BorderThickness="1,0,0,0" Padding="3,3">
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock x:Name="HuangLiXiuLabel" Text="星宿" FontSize="9" Foreground="#B88A5A" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                                                    <TextBlock x:Name="HuangLiXiuVal" FontSize="9" Foreground="#A6FFFFFF" Margin="0,2,0,0" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <Border x:Name="HuangLiCurrentDivider" Height="1" Background="#0DFFFFFF" Margin="0,0,0,4" />
                                    <StackPanel x:Name="HuangLiCurrentCard" Visibility="Collapsed">
                                        <TextBlock x:Name="HuangLiCurrentTitle" Text="当前时辰" FontSize="11" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,4" />
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <Border x:Name="HuangLiCurrentZhiCircle" Width="36" Height="36" CornerRadius="18" Background="#FF8A72" VerticalAlignment="Top">
                                                <TextBlock x:Name="HuangLiCurrentZhi" Text="午" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="6,0,4,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="HuangLiCurrentSummary" FontSize="11" Foreground="#FFFFFF" TextWrapping="Wrap" />
                                                <TextBlock x:Name="HuangLiCurrentDirections" FontSize="9" Foreground="#8B95A5" Margin="0,1,0,0" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Border x:Name="HuangLiCurrentLuckBadge" Grid.Column="2" Width="18" Height="18" CornerRadius="9" Background="#3A3A3A" VerticalAlignment="Top">
                                                <TextBlock x:Name="HuangLiCurrentLuckText" Text="吉" FontSize="9" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <Border x:Name="HuangLiCurrentYiCircle" Width="14" Height="14" CornerRadius="7" Background="#55D38A" VerticalAlignment="Top" Margin="0,1,4,0">
                                                <TextBlock x:Name="HuangLiCurrentYiCircleText" Text="宜" FontSize="8" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock x:Name="HuangLiCurrentYiText" FontSize="10" Foreground="#A6FFFFFF" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Border x:Name="HuangLiCurrentJiCircle" Width="14" Height="14" CornerRadius="7" Background="#FF8A72" VerticalAlignment="Top" Margin="0,1,4,0">
                                                <TextBlock x:Name="HuangLiCurrentJiCircleText" Text="忌" FontSize="8" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock x:Name="HuangLiCurrentJiText" FontSize="10" Foreground="#A6FFFFFF" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Border x:Name="HuangLiMoreBtn" Background="#18FFFFFF" CornerRadius="4" Padding="5,3" Cursor="Hand" MouseLeftButtonUp="HuangLiMore_Click">
                                            <TextBlock x:Name="HuangLiMoreText" Text="查看更多 ›" FontSize="10" Foreground="#8B95A5" HorizontalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Module ordering is controlled by the dashboard grid layout. -->
                        <StackPanel x:Name="ExtraModuleStack" Margin="0,0,0,0" Visibility="Collapsed" />

                        <!-- Countdown + Year Progress row -->
                        <Grid Margin="0,0,0,10" MinHeight="92">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" x:Name="CountdownCard" Style="{StaticResource FloatlyCard}" Padding="16">
                                <StackPanel x:Name="CountdownPanel" Visibility="Collapsed">
                                    <TextBlock x:Name="CountdownLabel" Text="距离 618" Style="{StaticResource CardTitle}" Margin="0,0,0,4" />
                                    <TextBlock x:Name="CountdownDays" Text="12 天" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,6" />
                                    <Border x:Name="CountdownTrack" Height="8" CornerRadius="4" Background="#38FFFFFF" ClipToBounds="True" Margin="0,0,0,4">
                                        <Border x:Name="CountdownFill" HorizontalAlignment="Left" CornerRadius="4" Background="#FF8A72" Width="0" />
                                    </Border>
                                    <TextBlock x:Name="CountdownHint" Text="目标日期" FontSize="10" Foreground="#8B95A5" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" x:Name="YearProgressCard" Style="{StaticResource FloatlyCard}" Padding="16">
                                <StackPanel x:Name="YearProgressPanel" Visibility="Collapsed">
                                    <TextBlock x:Name="YearProgressLabel" Text="2026 年进度" Style="{StaticResource CardTitle}" Margin="0,0,0,4" />
                                    <TextBlock x:Name="YearProgressPercent" Text="44.1%" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,6" />
                                    <Border x:Name="YearProgressTrack" Height="8" CornerRadius="4" Background="#38FFFFFF" ClipToBounds="True" Margin="0,0,0,4">
                                        <Border x:Name="YearProgressFill" HorizontalAlignment="Left" CornerRadius="4" Background="#5C8DFF" Width="0" />
                                    </Border>
                                    <TextBlock x:Name="YearProgressDetail" Text="已过 162 天 / 365 天" FontSize="10" Foreground="#8B95A5" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Todo + Pomodoro row -->
                        <Grid Margin="0,0,0,10" MinHeight="190">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource FloatlyCard}" Padding="16">
                                <StackPanel x:Name="TodoPanel">
                                    <Grid Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock x:Name="TodoTitleText" Text="今日待办" Style="{StaticResource CardTitle}" />
                                            <Border x:Name="TodoCountBadge" CornerRadius="8" Padding="5,1" Margin="5,0,0,0" Background="#225C8DFF">
                                                <TextBlock x:Name="TodoCountText" Text="0" FontSize="10" Foreground="#5C8DFF" FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>
                                        <Button Content="+" Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Click="AddTodo_Click" Background="#18FFFFFF" BorderThickness="0"
                                                Foreground="#DDE8FF" Cursor="Hand" FontSize="20" />
                                    </Grid>
                                    <Border x:Name="DividerBorder" Height="0" Visibility="Collapsed" />
                                    <ItemsControl x:Name="TodoList" Margin="0,0,0,4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource TodoCardBgBrush}" BorderBrush="{DynamicResource TodoCardBorderBrush}"
                                                        BorderThickness="1" CornerRadius="6" Padding="6,4" Margin="0,0,0,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <local:CircleCheckBox Grid.Column="0" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                              TagId="{Binding Id}" Click="TodoCheck_Click" />
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Background="{DynamicResource TodoTimeBadgeBrush}" CornerRadius="3" Padding="3,1" Margin="0,0,4,0" VerticalAlignment="Center">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasTime}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="{Binding Time}" FontSize="9" Foreground="{DynamicResource TodoAccentBrush}" FontWeight="SemiBold" />
                                                                </Border>
                                                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TodoTextBrush}" FontSize="11"
                                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                                           Tag="{Binding Id}" MouseLeftButtonDown="TodoTitle_DoubleClick" Cursor="Hand" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Content="{Binding PinIcon}" Width="20" Height="20" Padding="0" Tag="{Binding Id}" Click="TodoPin_Click"
                                                                    Background="Transparent" BorderThickness="0" Cursor="Hand" FontSize="11" ToolTip="置顶">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TodoPinInactiveBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Pinned}" Value="True">
                                                                                <Setter Property="Foreground" Value="{DynamicResource TodoPinActiveBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                            <Button Content="×" Width="20" Height="20" Padding="0" Tag="{Binding Id}" Click="TodoDelete_Click"
                                                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Foreground="{DynamicResource TodoDeleteBrush}" FontSize="13" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border x:Name="EmptyTodoPanel" Background="{DynamicResource TodoCardBgBrush}" BorderBrush="{DynamicResource TodoCardBorderBrush}"
                                            BorderThickness="1" CornerRadius="6" Padding="8,6" Margin="0,0,0,4" Visibility="Collapsed">
                                        <TextBlock x:Name="EmptyTodoText" Text="暂无待办" Foreground="{DynamicResource TodoEmptyBrush}" FontSize="11" TextAlignment="Center" />
                                    </Border>
                                    <Border x:Name="TodoOverflowBtn" Background="#18FFFFFF" CornerRadius="4" Padding="4,2" Margin="0,0,0,2" Cursor="Hand"
                                            MouseLeftButtonUp="TodoViewAll_Click" Visibility="Collapsed">
                                        <TextBlock x:Name="TodoOverflowText" Text="还有 0 条未显示 ›" FontSize="10" Foreground="{DynamicResource TodoLinkBrush}" HorizontalAlignment="Center" />
                                    </Border>
                                    <Border x:Name="TodoViewAllBtn" Background="Transparent" Padding="2" Cursor="Hand" MouseLeftButtonUp="TodoViewAll_Click">
                                        <TextBlock x:Name="TodoViewAllText" Text="查看全部 ›" FontSize="10" Foreground="{DynamicResource TodoLinkBrush}" HorizontalAlignment="Center" />
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource FloatlyCard}" Padding="16">
                                <StackPanel x:Name="PomodoroPanel" Visibility="Collapsed">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock x:Name="PomodoroPhaseText" Text="番茄钟" Style="{StaticResource CardTitle}" />
                                        <TextBlock x:Name="PomodoroSessionText" Text="准备开始" FontSize="10" Foreground="#8B95A5" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </Grid>
                                    <Grid HorizontalAlignment="Center" Margin="0,8,0,16">
                                        <Ellipse x:Name="PomodoroRingTrack" Width="156" Height="156" Stroke="#28FFFFFF" StrokeThickness="8" Fill="Transparent" />
                                        <Ellipse x:Name="PomodoroRingProgress" Width="156" Height="156" Stroke="#5C8DFF" StrokeThickness="8" Fill="Transparent"
                                                 StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform>
                                                <RotateTransform Angle="-90" />
                                            </Ellipse.RenderTransform>
                                        </Ellipse>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock x:Name="PomodoroCountdownText" Text="25:00" FontSize="34" FontWeight="SemiBold" Foreground="#FFFFFF" HorizontalAlignment="Center" />
                                            <TextBlock Text="准备开始" FontSize="14" Foreground="#A6FFFFFF" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                    <Border x:Name="PomodoroTrack" Height="0" Width="0" Visibility="Collapsed">
                                        <Border x:Name="PomodoroFill" Width="0" />
                                    </Border>
                                    <Button x:Name="PomodoroStartBtn" Content="开始专注" Height="44" Padding="0" Width="230"
                                            Click="PomodoroStart_Click" Background="#5C8DFF" Foreground="White"
                                            BorderThickness="0" Cursor="Hand" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    <Button x:Name="PomodoroResetBtn" Content="重置" Height="22" Padding="0" Margin="0,4,0,0"
                                            Click="PomodoroReset_Click" Background="Transparent" Foreground="#8B95A5"
                                            BorderThickness="0" Cursor="Hand" FontSize="10" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- OffWork + Salary row -->
                        <Grid Margin="0,0,0,10" MinHeight="120">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" x:Name="OffWorkCard" Style="{StaticResource FloatlyCard}" Padding="0">
                                <Grid>
                                    <Image Source="Assets/CardBackgrounds/star-sky-dark.png"
                                           Stretch="UniformToFill"
                                           Opacity="0.32"
                                           IsHitTestVisible="False"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <Border Background="#B80B1220" />
                                    <Border Padding="14">
                                        <StackPanel x:Name="OffWorkPanel" Visibility="Collapsed">
                                    <TextBlock x:Name="OffWorkLabel" Text="下班倒计时" Style="{StaticResource CardTitle}" Margin="0,0,0,8" />
                                    <TextBlock x:Name="OffWorkMainText" Text="07:56:05" FontSize="28" FontWeight="SemiBold"
                                               FontFamily="Consolas" Foreground="#F7FAFF" Margin="0,0,0,4" />
                                    <TextBlock Text="距离下班还有" FontSize="12" Foreground="#A6FFFFFF" Margin="0,0,0,8" />
                                    <Border x:Name="OffWorkTrack" Height="8" CornerRadius="4" Background="#27344D" ClipToBounds="True" Margin="0,0,0,10">
                                        <Border x:Name="OffWorkFill" HorizontalAlignment="Left" CornerRadius="4" Background="#5C6CFF" Width="0" />
                                    </Border>
                                    <TextBlock x:Name="OffWorkDetail" Text="" FontSize="11" Foreground="#8B95A5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" x:Name="SalaryPanel" Style="{StaticResource FloatlyCard}" Padding="0" Visibility="Collapsed">
                                <Grid>
                                    <Image Source="Assets/CardBackgrounds/coins.png"
                                           Stretch="UniformToFill"
                                           Opacity="0.24"
                                           IsHitTestVisible="False"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <Border Background="#C0151010" />
                                    <Border Padding="14">
                                        <StackPanel>
                                        <TextBlock x:Name="SalaryLabel" Text="今日已赚薪水" Style="{StaticResource CardTitle}" Margin="0,0,0,8" />
                                        <TextBlock x:Name="SalaryAmount" Text="¥0.00" FontSize="30" FontWeight="Bold"
                                                   FontFamily="Consolas" Foreground="#F8C34A" Margin="0,0,0,4" />
                                        <TextBlock x:Name="SalarySubtitle" Text="" FontSize="12" Foreground="#D7E4C2" Margin="0,0,0,12" />
                                        <Border Height="1" Background="#24FFFFFF" Margin="0,0,0,10" />
                                        <TextBlock Text="时薪与今日工作时长按设置实时计算" FontSize="11" Foreground="#A6FFFFFF" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border x:Name="DailyQuoteBanner" Style="{StaticResource FloatlyCard}" Margin="0,0,0,10" Padding="0" MinHeight="100" Visibility="Collapsed">
                            <Grid>
                                <Image Source="Assets/CardBackgrounds/star-sky-dark.png"
                                       Stretch="UniformToFill"
                                       Opacity="0.46"
                                       IsHitTestVisible="False"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <Border Background="#B80E1625" />
                                <StackPanel Margin="18,16">
                                    <TextBlock Text="✦ 每日一句" FontSize="15" FontWeight="SemiBold" Foreground="#DDE8FF" Margin="0,0,0,10" />
                                    <TextBlock x:Name="DailyQuoteText" FontSize="20" Foreground="#FFFFFF" FontWeight="SemiBold"
                                               TextWrapping="Wrap" Visibility="Collapsed" />
                                    <TextBlock Text="坚持，是比努力更重要的能力。" FontSize="12" Foreground="#A6FFFFFF" Margin="0,8,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Scratch notes -->
                        <Border x:Name="ScratchPanel" Style="{StaticResource FloatlyCard}" Margin="0,0,0,10" Padding="16" MinHeight="96"
                                Cursor="Hand" MouseLeftButtonUp="ScratchPanel_Click" Visibility="Collapsed">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock x:Name="ScratchTitleText" Text="速记便签" Style="{StaticResource CardTitle}" />
                                        <Border x:Name="ScratchCountBadge" CornerRadius="8" Padding="5,1" Margin="5,0,0,0" Background="#225C8DFF">
                                            <TextBlock x:Name="ScratchCountText" Text="0" FontSize="10" Foreground="#5C8DFF" FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock x:Name="ScratchExpandText" Text="+" FontSize="14" Foreground="#8B95A5"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonUp="ScratchExpand_Click" />
                                </Grid>
                                <Border x:Name="ScratchPreviewCard" CornerRadius="8" Padding="10,8" Background="#665C4A1E" BorderBrush="#14FFFFFF" BorderThickness="1"
                                        MouseLeftButtonUp="ScratchExpand_Click">
                                    <StackPanel>
                                        <TextBlock x:Name="ScratchPreviewTitle" FontSize="11" FontWeight="SemiBold" Foreground="#E8D5A0" TextTrimming="CharacterEllipsis" Margin="0,0,0,2" />
                                        <TextBlock x:Name="ScratchPreviewContent" FontSize="10" Foreground="#A6FFFFFF" TextWrapping="Wrap" MaxHeight="28" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="ScratchEmptyText" Text="点击新建便签" FontSize="10" Foreground="#6B7280" Margin="0,4,0,0" Visibility="Collapsed"
                                           MouseLeftButtonUp="ScratchExpand_Click" Cursor="Hand" />
                            </StackPanel>
                        </Border>

                        <!-- Calendar: week + month side by side -->
                        <Grid x:Name="CalendarSection" Margin="0,0,0,0" MinHeight="220" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource FloatlyCard}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="本周日程" Style="{StaticResource CardTitle}" Margin="0,0,0,6" />
                                    <Grid x:Name="WeekCalendarPanel" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource FloatlyCard}" Padding="16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,4">
                                        <Button x:Name="CalPrevBtn" Content="‹" Width="20" Height="20" Padding="0"
                                                Click="CalPrev_Click" Background="Transparent" BorderThickness="0"
                                                Foreground="#8B95A5" Cursor="Hand" FontSize="12" HorizontalAlignment="Left" />
                                        <TextBlock x:Name="CalendarTitleText" Text="6月 2026" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#A6FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Button x:Name="CalNextBtn" Content="›" Width="20" Height="20" Padding="0"
                                                Click="CalNext_Click" Background="Transparent" BorderThickness="0"
                                                Foreground="#8B95A5" Cursor="Hand" FontSize="12" HorizontalAlignment="Right" />
                                    </Grid>
                                    <UniformGrid x:Name="WeekdayHeader" Rows="1" Columns="7" Margin="0,0,0,2" />
                                    <Grid x:Name="CalendarPanel" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0" Visibility="Collapsed">
                                        <Button x:Name="CalWeekModeBtn" Content="周" Width="22" Height="18" Padding="0" Click="CalWeekMode_Click"
                                                Background="Transparent" BorderThickness="0" Foreground="#5C8DFF" FontSize="9" />
                                        <Button x:Name="CalMonthModeBtn" Content="月" Width="22" Height="18" Padding="0" Click="CalMonthMode_Click"
                                                Background="Transparent" BorderThickness="0" Foreground="#6B7280" FontSize="9" Margin="4,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom toolbar -->
                <Border Grid.Row="2" x:Name="BottomToolbar" Background="#D81A1D24" CornerRadius="18" Padding="14,8" Margin="0,10,0,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚙" FontSize="14" Foreground="#A6FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="快捷设置" FontSize="12" Foreground="#DDE8FF" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Visible">
                            <TextBlock Text="透明度" FontSize="10" Foreground="#8B95A5" VerticalAlignment="Center" />
                            <Slider x:Name="OpacitySlider" Width="120" Minimum="30" Maximum="100" Value="100"
                                    ValueChanged="OpacitySlider_ValueChanged" Margin="8,0,10,0" />
                            <TextBlock x:Name="OpacityValueText" Text="100%" FontSize="10" Foreground="#A6FFFFFF" VerticalAlignment="Center" />
                            <TextBlock Text="字体大小" FontSize="10" Foreground="#8B95A5" VerticalAlignment="Center" Margin="18,0,0,0" />
                            <Slider x:Name="FontSizeSlider" Width="120" Minimum="10" Maximum="16" Value="12" TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="FontSizeSlider_ValueChanged" Margin="8,0,10,0" />
                            <TextBlock x:Name="FontSizeValueText" Text="12px" FontSize="10" Foreground="#A6FFFFFF" VerticalAlignment="Center" />
                        </StackPanel>
                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ThemeToggleBtn" Content="🌙" Width="28" Height="28" Padding="0"
                                    Click="ThemeToggleBtn_Click" Background="Transparent" BorderThickness="0"
                                    Foreground="#A6FFFFFF" Cursor="Hand" FontSize="14" ToolTip="切换主题" />
                            <Button x:Name="ToolbarPinBtn" Grid.Column="1" Content="📌 置顶" Height="28" Padding="8,0"
                                    Click="PinBtn_Click" Background="Transparent" BorderThickness="0"
                                    Foreground="#A6FFFFFF" Cursor="Hand" FontSize="10" HorizontalAlignment="Center" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="穿透" FontSize="10" Foreground="#8B95A5" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <CheckBox x:Name="ClickThroughToggle" VerticalAlignment="Center" Click="ClickThroughToggle_Click" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Todo input -->
                <Grid Grid.Row="3" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewTodoBox" Height="30" Background="#252A33" Foreground="#FFFFFF"
                             BorderBrush="#0DFFFFFF" Padding="8,4" FontSize="12" Cursor="IBeam"
                             KeyDown="NewTodoBox_KeyDown" GotFocus="NewTodoBox_GotFocus" LostFocus="NewTodoBox_LostFocus" />
                    <Button x:Name="AddButton" Grid.Column="1" Content="添加" Width="52" Height="30" Margin="6,0,0,0"
                            Click="AddTodo_Click" Background="#5C8DFF" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="11" />
                </Grid>
            </Grid>

            <Grid x:Name="ResizeGripLayer">
                <Thumb Style="{StaticResource ResizeGripThumb}" Width="12" HorizontalAlignment="Left" Cursor="SizeWE" DragDelta="ResizeLeft_DragDelta" />
                <Thumb Style="{StaticResource ResizeGripThumb}" Width="12" HorizontalAlignment="Right" Cursor="SizeWE" DragDelta="ResizeRight_DragDelta" />
                <Thumb Style="{StaticResource ResizeGripThumb}" Height="12" VerticalAlignment="Top" Cursor="SizeNS" DragDelta="ResizeTop_DragDelta" />
                <Thumb Style="{StaticResource ResizeGripThumb}" Height="12" VerticalAlignment="Bottom" Cursor="SizeNS" DragDelta="ResizeBottom_DragDelta" />
                <Thumb Style="{StaticResource ResizeGripThumb}" Width="18" Height="18" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" DragDelta="ResizeTopLeft_DragDelta" />
                <Thumb Style="{StaticResource ResizeGripThumb}" Width="18" Height="18" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" DragDelta="ResizeTopRight_DragDelta" />
                <Thumb Style="{StaticResource ResizeGripThumb}" Width="18" Height="18" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" DragDelta="ResizeBottomLeft_DragDelta" />
                <Thumb Style="{StaticResource ResizeGripThumb}" Width="18" Height="18" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragDelta="ResizeBottomRight_DragDelta" />
            </Grid>
        </Grid>
    </Border>
</Window>

