<Window x:Class="DeskLite.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Floatly 设置"
        Width="440"
        Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FAFAFA"
        Foreground="#111827"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="SettingsBg" Color="#FAFAFA" />
        <SolidColorBrush x:Key="SettingsText" Color="#111827" />
        <SolidColorBrush x:Key="SettingsMuted" Color="#6B7280" />
        <SolidColorBrush x:Key="SettingsBorder" Color="#D1D5DB" />
        <SolidColorBrush x:Key="SettingsInputBg" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SettingsAccent" Color="#2563EB" />

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Foreground" Value="{StaticResource SettingsMuted}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="Transparent" BorderThickness="0,0,0,2" BorderBrush="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource SettingsAccent}" />
                                <Setter Property="Foreground" Value="{StaticResource SettingsText}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource SettingsText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="{StaticResource SettingsText}" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,16,0" />
            <Setter Property="Foreground" Value="{StaticResource SettingsText}" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SettingsMuted}" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SettingsMuted}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource SettingsMuted}" />
        </Style>
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SettingsInputBg}" />
            <Setter Property="Foreground" Value="{StaticResource SettingsText}" />
            <Setter Property="BorderBrush" Value="{StaticResource SettingsBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style x:Key="SettingsComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SettingsInputBg}" />
            <Setter Property="Foreground" Value="{StaticResource SettingsText}" />
            <Setter Property="BorderBrush" Value="{StaticResource SettingsBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style x:Key="SettingsSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Foreground" Value="{StaticResource SettingsAccent}" />
        </Style>
        <Style x:Key="SettingsNumericBox" TargetType="TextBox" BasedOn="{StaticResource SettingsTextBox}">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="28" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SettingsAccent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="88" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SettingsInputBg}" />
            <Setter Property="Foreground" Value="{StaticResource SettingsText}" />
            <Setter Property="BorderBrush" Value="{StaticResource SettingsBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="88" />
        </Style>
        <Style x:Key="ModuleOrderListBox" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource SettingsInputBg}" />
            <Setter Property="Foreground" Value="{StaticResource SettingsText}" />
            <Setter Property="BorderBrush" Value="{StaticResource SettingsBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
        </Style>
        <Style x:Key="ModuleOrderButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="Padding" Value="12,6" />
        </Style>
    </Window.Resources>

    <Grid Margin="16" Background="{StaticResource SettingsBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="{StaticResource SettingsBg}" BorderThickness="0">
            <TabItem Header="常规">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,0" Background="{StaticResource SettingsBg}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="窗口" />
                        <CheckBox x:Name="ChkAlwaysOnTop" Content="窗口置顶" />
                        <CheckBox x:Name="ChkAutoStart" Content="开机自启" />
                        <CheckBox x:Name="ChkClickThrough" Content="鼠标穿透（开启后无法拖动窗口）" />
                        <CheckBox x:Name="ChkGlobalHotkey" Content="全局快捷键" />

                        <TextBlock Style="{StaticResource SectionTitle}" Text="快捷键" Margin="0,8,0,10" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="88" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="显示/隐藏" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtHotkeyShowHide" Grid.Column="1" Margin="8,0,8,0"
                                     Style="{StaticResource SettingsTextBox}" IsReadOnly="True"
                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                     GotFocus="HotkeyShowHide_GotFocus" LostFocus="HotkeyTextBox_LostFocus" />
                            <Button x:Name="BtnRecordShowHide" Grid.Column="2" Content="录制"
                                    Style="{StaticResource SecondaryButton}" Padding="12,6" MinWidth="56"
                                    Click="BtnRecordShowHide_Click" />
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="88" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="快速待办" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtHotkeyQuickTodo" Grid.Column="1" Margin="8,0,8,0"
                                     Style="{StaticResource SettingsTextBox}" IsReadOnly="True"
                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                     GotFocus="HotkeyQuickTodo_GotFocus" LostFocus="HotkeyTextBox_LostFocus" />
                            <Button x:Name="BtnRecordQuickTodo" Grid.Column="2" Content="录制"
                                    Style="{StaticResource SecondaryButton}" Padding="12,6" MinWidth="56"
                                    Click="BtnRecordQuickTodo_Click" />
                        </Grid>
                        <TextBlock x:Name="HotkeyStatusText" Style="{StaticResource HintText}"
                                   Text="点击录制或聚焦输入框后按下组合键" Margin="0,0,0,14" />

                        <TextBlock Style="{StaticResource SectionTitle}" Text="工作时间" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="上班时间" FontSize="11" Margin="0,0,0,4" />
                                <TextBox x:Name="TxtWorkStartTime" Style="{StaticResource SettingsTextBox}" Text="09:00" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="—" VerticalAlignment="Bottom" Margin="10,0,10,8" />
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="下班时间" FontSize="11" Margin="0,0,0,4" />
                                <TextBox x:Name="TxtWorkEndTime" Style="{StaticResource SettingsTextBox}" Text="18:00" />
                            </StackPanel>
                        </Grid>
                        <CheckBox x:Name="ChkOffWorkWeekdaysOnly" Content="仅工作日显示下班倒计时" Margin="0,0,0,14" />

                        <TextBlock Style="{StaticResource SectionTitle}" Text="摸鱼收入" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="月薪（元）" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtMonthlySalary" Grid.Column="1" Style="{StaticResource SettingsNumericBox}"
                                     Width="96" />
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="每月工作天数" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtWorkDaysPerMonth" Grid.Column="1" Style="{StaticResource SettingsNumericBox}"
                                     Width="56" />
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="每日工作小时" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtWorkHoursPerDay" Grid.Column="1" Style="{StaticResource SettingsNumericBox}"
                                     Width="56" />
                        </Grid>

                        <TextBlock Style="{StaticResource SectionTitle}" Text="时钟" />
                        <CheckBox x:Name="ChkTime24h" Content="24 小时制" />
                        <CheckBox x:Name="ChkShowSeconds" Content="显示秒" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="外观">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,0" Background="{StaticResource SettingsBg}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="主题" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <RadioButton x:Name="RbThemeDark" Content="深色" GroupName="Theme" />
                            <RadioButton x:Name="RbThemeLight" Content="浅色" GroupName="Theme" />
                        </StackPanel>

                        <TextBlock Style="{StaticResource SectionTitle}" Text="窗口透明度" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SliderOpacity" Grid.Column="0" Style="{StaticResource SettingsSlider}"
                                    Minimum="30" Maximum="100" IsSnapToTickEnabled="True" TickFrequency="1"
                                    ValueChanged="SliderOpacity_ValueChanged" />
                            <TextBox x:Name="TxtOpacity" Grid.Column="1" Style="{StaticResource SettingsNumericBox}"
                                     LostFocus="TxtOpacity_LostFocus" KeyDown="TxtOpacity_KeyDown" />
                        </Grid>
                        <TextBlock Style="{StaticResource HintText}" Text="30–100（数值越大越不透明）" Margin="0,0,0,14" />

                        <TextBlock Style="{StaticResource SectionTitle}" Text="字号" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SliderFontSize" Grid.Column="0" Style="{StaticResource SettingsSlider}"
                                    Minimum="10" Maximum="16" IsSnapToTickEnabled="True" TickFrequency="1"
                                    ValueChanged="SliderFontSize_ValueChanged" />
                            <TextBox x:Name="TxtFontSize" Grid.Column="1" Style="{StaticResource SettingsNumericBox}"
                                     LostFocus="TxtFontSize_LostFocus" KeyDown="TxtFontSize_KeyDown" />
                        </Grid>
                        <TextBlock Style="{StaticResource HintText}" Text="10–16 pt" Margin="0,0,0,14" />

                        <TextBlock Style="{StaticResource SectionTitle}" Text="字体" />
                        <ComboBox x:Name="CmbFontFamily" Style="{StaticResource SettingsComboBox}"
                                  IsEditable="True" Margin="0,0,0,4" />
                        <TextBlock Style="{StaticResource HintText}" Text="从列表选择或输入已安装字体名称" Margin="0,0,0,14" />

                        <TextBlock Style="{StaticResource SectionTitle}" Text="字体颜色" />
                        <UniformGrid x:Name="FontColorPalette" Columns="6" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtCustomFontColor" Style="{StaticResource SettingsTextBox}"
                                     ToolTip="留空则使用主题默认颜色，支持 #RRGGBB" />
                            <Button x:Name="BtnClearFontColor" Grid.Column="1" Content="恢复默认"
                                    Margin="8,0,0,0" Style="{StaticResource SecondaryButton}"
                                    Padding="12,6" Click="BtnClearFontColor_Click" />
                        </Grid>
                        <TextBlock Style="{StaticResource HintText}" Text="选择预设或输入自定义十六进制颜色" Margin="0,0,0,14" />

                        <TextBlock Style="{StaticResource SectionTitle}" Text="皮肤" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <RadioButton x:Name="RbSkinDefault" Content="默认" GroupName="Skin" />
                            <RadioButton x:Name="RbSkinSolid" Content="纯色" GroupName="Skin" />
                            <RadioButton x:Name="RbSkinImage" Content="自定义图片" GroupName="Skin" />
                            <RadioButton x:Name="RbSkinVideo" Content="视频" GroupName="Skin" />
                        </StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtSkinImagePath" Grid.Column="0" Height="32"
                                     Style="{StaticResource SettingsTextBox}" IsReadOnly="True" />
                            <Button x:Name="BtnBrowseSkin" Grid.Column="1" Content="浏览图片…"
                                    Margin="8,0,0,0" Style="{StaticResource SecondaryButton}"
                                    Click="BtnBrowseSkin_Click" />
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtSkinVideoPath" Grid.Column="0" Height="32"
                                     Style="{StaticResource SettingsTextBox}" IsReadOnly="True" />
                            <Button x:Name="BtnBrowseSkinVideo" Grid.Column="1" Content="浏览视频…"
                                    Margin="8,0,0,0" Style="{StaticResource SecondaryButton}"
                                    Click="BtnBrowseSkinVideo_Click" />
                        </Grid>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="视频背景：建议使用短视频循环，静音播放；占用更多 CPU/GPU 资源"
                                   TextWrapping="Wrap" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SliderSkinOverlay" Grid.Column="0" Style="{StaticResource SettingsSlider}"
                                    Minimum="0" Maximum="85" IsSnapToTickEnabled="True" TickFrequency="1"
                                    ValueChanged="SliderSkinOverlay_ValueChanged" />
                            <TextBox x:Name="TxtSkinOverlay" Grid.Column="1" Style="{StaticResource SettingsNumericBox}"
                                     Width="56" LostFocus="TxtSkinOverlay_LostFocus" KeyDown="TxtSkinOverlay_KeyDown" />
                        </Grid>
                        <TextBlock Style="{StaticResource HintText}" Text="图片/视频遮罩 0–85%（提高可读性）" Margin="0,0,0,14" />
                        <TextBlock Style="{StaticResource HintText}" Text="拖拽窗口四边或四角可调整大小" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="天气">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,0" Background="{StaticResource SettingsBg}">
                    <StackPanel>
                        <CheckBox x:Name="ChkShowWeather" Content="显示天气" />
                        <CheckBox x:Name="ChkShowCityName" Content="显示城市名称" />
                        <CheckBox x:Name="ChkShowSunrise" Content="日出日落" />
                        <CheckBox x:Name="ChkShowTomorrow" Content="明日天气" />

                        <TextBlock Style="{StaticResource SectionTitle}" Text="城市定位" Margin="0,8,0,10" />
                        <CheckBox x:Name="ChkAutoLocate" Content="自动定位城市（启动时与每 24 小时刷新）" />
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtCity" Grid.Column="0" Height="32"
                                     Style="{StaticResource SettingsTextBox}" />
                            <Button x:Name="BtnDetectLocation" Grid.Column="1" Content="立即定位"
                                    Margin="8,0,0,0" Style="{StaticResource SecondaryButton}"
                                    Click="BtnDetectLocation_Click" />
                        </Grid>
                        <TextBlock x:Name="LocationStatusText" Style="{StaticResource HintText}" Margin="0,8,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="日历">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,0" Background="{StaticResource SettingsBg}">
                    <StackPanel>
                        <CheckBox x:Name="ChkShowWeekStrip" Content="显示万年历" />
                        <CheckBox x:Name="ChkShowHuangLi" Content="显示黄历详情（宜忌、神煞、时辰）" Margin="0,0,0,14" />
                        <TextBlock Style="{StaticResource SectionTitle}" Text="默认视图" Margin="0,8,0,10" />
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="RbCalWeek" Content="周历" GroupName="Calendar" />
                            <RadioButton x:Name="RbCalMonth" Content="月历" GroupName="Calendar" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="模块">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,0" Background="{StaticResource SettingsBg}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="显示顺序" />
                        <TextBlock Style="{StaticResource HintText}" Text="使用上移/下移调整桌面模块排列顺序" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ListBox x:Name="ModuleOrderList" Grid.Column="0" Height="196"
                                     Style="{StaticResource ModuleOrderListBox}"
                                     SelectionChanged="ModuleOrderList_SelectionChanged" />
                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                <Button x:Name="BtnModuleUp" Content="上移" Style="{StaticResource ModuleOrderButton}"
                                        Click="BtnModuleUp_Click" />
                                <Button x:Name="BtnModuleDown" Content="下移" Margin="0,6,0,0"
                                        Style="{StaticResource ModuleOrderButton}" Click="BtnModuleDown_Click" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Style="{StaticResource SectionTitle}" Text="桌面模块" />
                        <CheckBox x:Name="ChkYearProgress" Content="年进度" />
                        <CheckBox x:Name="ChkOffWorkCountdown" Content="下班倒计时" />
                        <CheckBox x:Name="ChkSalaryHelper" Content="摸鱼小助手" />
                        <CheckBox x:Name="ChkCountdown" Content="倒数日" />
                        <CheckBox x:Name="ChkPomodoro" Content="番茄钟" />
                        <CheckBox x:Name="ChkDailyQuote" Content="每日一句" />
                        <CheckBox x:Name="ChkScratch" Content="速记便签" />
                        <CheckBox x:Name="ChkTodoReminder" Content="待办到时提醒" />

                        <TextBlock Style="{StaticResource SectionTitle}" Text="番茄钟时长（分钟）" Margin="0,8,0,10" />
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="专注" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtPomodoroWork" Grid.Column="1" Style="{StaticResource SettingsNumericBox}"
                                     Width="56" />
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="短休息" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtPomodoroBreak" Grid.Column="1" Style="{StaticResource SettingsNumericBox}"
                                     Width="56" />
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="长休息" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtPomodoroLongBreak" Grid.Column="1" Style="{StaticResource SettingsNumericBox}"
                                     Width="56" />
                        </Grid>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="长休息前番茄数" VerticalAlignment="Center" />
                            <TextBox x:Name="TxtPomodoroSessions" Grid.Column="1" Style="{StaticResource SettingsNumericBox}"
                                     Width="56" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                    IsCancel="True" Click="Cancel_Click" />
            <Button Content="保存" Style="{StaticResource PrimaryButton}" IsDefault="True"
                    Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
