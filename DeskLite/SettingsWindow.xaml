                                            </StackPanel>
                                        </ToggleButton>
                                        <ToggleButton x:Name="TbSkinSolid" Margin="0,0,8,0" Padding="10,8" Style="{StaticResource SecondaryToggleButton}"
                                                      Click="SkinToggle_Click" Tag="solid">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="纯色" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </ToggleButton>
                                        <ToggleButton x:Name="TbSkinImage" Margin="0,0,8,0" Padding="10,8" Style="{StaticResource SecondaryToggleButton}"
                                                      Click="SkinToggle_Click" Tag="image">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="图片背景" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </ToggleButton>
                                        <ToggleButton x:Name="TbSkinVideo" Padding="10,8" Style="{StaticResource SecondaryToggleButton}"
                                                      Click="SkinToggle_Click" Tag="video">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="视频背景" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </ToggleButton>
                                    </UniformGrid>
                                    <RadioButton x:Name="RbSkinDefault" GroupName="Skin" Visibility="Collapsed" />
                                    <RadioButton x:Name="RbSkinSolid" GroupName="Skin" Visibility="Collapsed" />
                                    <RadioButton x:Name="RbSkinImage" GroupName="Skin" Visibility="Collapsed" />
                                    <RadioButton x:Name="RbSkinVideo" GroupName="Skin" Visibility="Collapsed" />
                                    <Grid x:Name="SkinImagePathRow" Margin="0,0,0,8" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtSkinImagePath" Style="{StaticResource SettingsTextBox}" IsReadOnly="True" />
                                        <Button x:Name="BtnBrowseSkin" Grid.Column="1" Content="浏览图片..."
                                                Margin="8,0,0,0" Style="{StaticResource SecondaryButton}"
                                                Click="BtnBrowseSkin_Click" />
                                    </Grid>
                                    <Grid x:Name="SkinVideoPathRow" Margin="0,0,0,8" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtSkinVideoPath" Style="{StaticResource SettingsTextBox}" IsReadOnly="True" />
                                        <Button x:Name="BtnBrowseSkinVideo" Grid.Column="1" Content="浏览视频..."
                                                Margin="8,0,0,0" Style="{StaticResource SecondaryButton}"
                                                Click="BtnBrowseSkinVideo_Click" />
                                    </Grid>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="62" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.ColumnSpan="3" Style="{StaticResource FieldLabel}" Text="背景遮罩透明度" FontWeight="SemiBold" Foreground="{StaticResource SettingsText}" />
                                        <TextBox x:Name="TxtSkinOverlay" Grid.Column="3" Style="{StaticResource CompactValueBox}"
                                                 LostFocus="TxtSkinOverlay_LostFocus" KeyDown="TxtSkinOverlay_KeyDown" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="0%" Style="{StaticResource HintText}" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                        <Slider x:Name="SliderSkinOverlay" Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsSlider}"
                                                Minimum="0" Maximum="85" IsSnapToTickEnabled="True" TickFrequency="1"
                                                ValueChanged="SliderSkinOverlay_ValueChanged" Margin="10,0" />
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="85%" Style="{StaticResource HintText}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </Grid>

                                    <Border Height="1" Background="#14FFFFFF" Margin="0,0,0,8" />
                                    <TextBlock Style="{StaticResource CardTitle}" Text="窗口大小" Margin="0,0,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="128" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource HintText}"
                                                   Text="拖拽窗口四边或四角可调整大小"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="1" Height="42" CornerRadius="8" BorderBrush="{StaticResource SettingsBorder}" BorderThickness="1"
                                                Background="#121820" HorizontalAlignment="Right" Width="112">
                                            <Grid>
                                                <Border Margin="14,10" BorderBrush="#44FFFFFF" BorderThickness="1" CornerRadius="4" />
                                                <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                           Foreground="{StaticResource SettingsMuted}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="6" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border x:Name="SectionModules" Height="0" Visibility="Collapsed" />
                            <Border Style="{StaticResource SettingsCard}" Padding="16,14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.36*" />
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="1" />
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.ColumnSpan="5" Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="&#xECAA;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="#B7C7E2" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Style="{StaticResource CardTitle}" Text="模块" Margin="0" />
                                    </StackPanel>

                                    <Grid Grid.Row="1" Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="显示顺序（拖拽排序）" Margin="0,0,0,8" />
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="58" />
                                            </Grid.ColumnDefinitions>
                                            <ListBox x:Name="ModuleOrderList" Height="176" Style="{StaticResource ModuleOrderListBox}"
                                                     SelectionChanged="ModuleOrderList_SelectionChanged" />
                                            <Grid Grid.Column="2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Button x:Name="BtnModuleUp" Grid.Row="0" Style="{StaticResource ModuleOrderButton}"
                                                        Click="BtnModuleUp_Click">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="&#xE70E;" FontFamily="Segoe MDL2 Assets" FontSize="9" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="上移" />
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="BtnModuleDown" Grid.Row="1" Style="{StaticResource ModuleOrderButton}"
                                                        Click="BtnModuleDown_Click">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="9" Margin="0,0,4,0" VerticalAlignment="Center" />
                                                        <TextBlock Text="下移" />
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="BtnResetModuleOrder" Grid.Row="3" Content="重置顺序"
                                                        Style="{StaticResource ModuleOrderButton}" Click="BtnResetModuleOrder_Click" />
                                            </Grid>
                                        </Grid>
                                    </Grid>

                                    <Border Grid.Row="1" Grid.Column="2" Background="#12FFFFFF" />

                                    <Border Grid.Row="1" Grid.Column="4" Background="#30141D2B" CornerRadius="8" Padding="14,12">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource CardTitle}" Text="番茄钟配置" Margin="0,0,0,14" />
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource FieldLabel}" Text="专注时长" Foreground="{StaticResource SettingsText}" />
                                                <Grid Grid.Column="1">
                                                    <TextBox x:Name="TxtPomodoroWork" Style="{StaticResource PomodoroValueBox}" />
                                                    <TextBlock Text="分钟" Foreground="{StaticResource SettingsMuted}" HorizontalAlignment="Right" Margin="0,0,12,0" VerticalAlignment="Center" />
                                                </Grid>
                                            </Grid>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource FieldLabel}" Text="短休息时长" Foreground="{StaticResource SettingsText}" />
                                                <Grid Grid.Column="1">
                                                    <TextBox x:Name="TxtPomodoroBreak" Style="{StaticResource PomodoroValueBox}" />
                                                    <TextBlock Text="分钟" Foreground="{StaticResource SettingsMuted}" HorizontalAlignment="Right" Margin="0,0,12,0" VerticalAlignment="Center" />
                                                </Grid>
                                            </Grid>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource FieldLabel}" Text="长休息时长" Foreground="{StaticResource SettingsText}" />
                                                <Grid Grid.Column="1">
                                                    <TextBox x:Name="TxtPomodoroLongBreak" Style="{StaticResource PomodoroValueBox}" />
                                                    <TextBlock Text="分钟" Foreground="{StaticResource SettingsMuted}" HorizontalAlignment="Right" Margin="0,0,12,0" VerticalAlignment="Center" />
                                                </Grid>
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource FieldLabel}" Text="长休息前番茄数" Foreground="{StaticResource SettingsText}" />
                                                <Grid Grid.Column="1">
                                                    <TextBox x:Name="TxtPomodoroSessions" Style="{StaticResource PomodoroValueBox}" />
                                                    <TextBlock Text="个" Foreground="{StaticResource SettingsMuted}" HorizontalAlignment="Right" Margin="0,0,12,0" VerticalAlignment="Center" />
                                                </Grid>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="2" Background="#B80D1521" BorderBrush="#18FFFFFF" BorderThickness="0,1,0,0" Padding="18,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnRestoreDefaults" Style="{StaticResource SecondaryButton}"
                                Padding="12,9" Margin="0,0,14,0" Click="BtnRestoreDefaults_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="恢复默认设置" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnOpenRepository" Style="{StaticResource LinkButton}"
                                Padding="8,6" Margin="0,0,10,0" Click="BtnOpenRepository_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="关于" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="VersionText" Text="版本 2.0.7"
                                   FontSize="11" Foreground="#66FFFFFF" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="取消" Style="{StaticResource SecondaryButton}" Margin="0,0,14,0"
                                IsCancel="True" Click="Cancel_Click" />
                        <Button Content="应用" Style="{StaticResource SecondaryButton}" Margin="0,0,14,0"
                                Click="Apply_Click" />
                        <Button Content="保存设置" Style="{StaticResource PrimaryButton}" IsDefault="True"
                                Click="Save_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>


